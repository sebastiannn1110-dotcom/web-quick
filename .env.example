# Public site configuration
NEXT_PUBLIC_SITE_URL="https://example.quicksol.test"

# Current optional CRM forwarding
CRM_WEBHOOK_URL="https://example.invalid/webhooks/quicksol"

# Supabase - future phase
NEXT_PUBLIC_SUPABASE_URL="https://example-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_example"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_example"
SUPABASE_SERVICE_ROLE_KEY="sb_secret_example"
SUPABASE_DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Email notifications - server only
RESEND_API_KEY="re_example"
EMAIL_FROM="Quicksol <notifications@example.quicksol.test>"
ADMIN_NOTIFICATION_EMAILS="sales@example.quicksol.test,ops@example.quicksol.test"

# OpenAI - future phase, server only
OPENAI_API_KEY="sk-example"
OPENAI_MODEL="gpt-5-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-large"

# LinkedIn - future phase
LINKEDIN_CLIENT_ID="example-client-id"
LINKEDIN_CLIENT_SECRET="example-client-secret"
LINKEDIN_REDIRECT_URI="https://example.quicksol.test/api/linkedin/callback"
LINKEDIN_ORGANIZATION_ID="123456789"
LINKEDIN_SYNC_MODE="manual"
LINKEDIN_TOKEN_ENCRYPTION_KEY="base64-example-32-byte-key"

# Operations - future phase
CRON_SECRET="example-cron-secret"
CHECKOUT_MODE="rfq"
ADMIN_BOOTSTRAP_EMAILS="admin@example.quicksol.test"
MAX_IMAGE_UPLOAD_MB="10"
MAX_VIDEO_UPLOAD_MB="200"
AI_ASSISTANT_ENABLED="false"
LINKEDIN_API_ENABLED="false"
